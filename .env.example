# ═══════════════════════════════════════
# MY VERY OWN API — Environment Template
# Copy to .env and fill in secrets. Never commit .env.
# ═══════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT Secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-long-random-string

# ─── LLM ───
# Gemini Flash is the flagship engine for K-Pop (cheapest, great quality)
GEMINI_API_KEY=your_gemini_key_here

# ─── Auth ───
# Magic link email sender (use SendGrid, Mailgun, or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="My Very Own <hello@myveryown.page>"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Apple OAuth (https://developer.apple.com)
APPLE_CLIENT_ID=com.myveryown.signin
APPLE_TEAM_ID=your_team_id
APPLE_KEY_ID=your_key_id
APPLE_PRIVATE_KEY=your_private_key_base64

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_KPOP_MONTHLY=price_...
STRIPE_PRICE_KPOP_ANNUAL=price_...

# ─── Cortex Memory ───
CORTEX_URL=https://cortex-production-809e.up.railway.app
CORTEX_API_KEY=your_cortex_api_key

# ─── Database ───
# Local: sqlite file. Production: Railway will inject DATABASE_URL for Postgres
DATABASE_URL=file:./data/myveryown.db
